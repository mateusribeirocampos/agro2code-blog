---
import { languages } from '../i18n/ui';
import { buildLanguagePickerHref, translatePathForLanguage } from '../utils/language-picker.js';
interface Props {
  translatedPaths?: Partial<Record<'en' | 'pt', string>>;
}

const { translatedPaths } = Astro.props as Props;
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // Remove trailing slash
const currentPath = Astro.url.pathname.replace(base, ''); // Remove base from current path
const lang = currentPath.startsWith('/pt') ? 'pt' : 'en';

function buildHref(code: string) {
  const translatedPath = translatedPaths?.[code as 'en' | 'pt'];
  return buildLanguagePickerHref({
    base,
    currentPath,
    code,
    translatedPath,
    translatePath: translatePathForLanguage,
  });
}

---
<ul>
  {Object.entries(languages).map(([code, label])=>(
    <li>
      <a
        href={buildHref(code)}
        aria-current={lang === code ? 'page' : undefined}
      >
        {label}
      </a>
    </li>
  ))}
</ul>
<style>
	ul {
		gap: 1em;
	}
  a {
    text-decoration: none;
    color: rgb(var(--black));
    font-size: 0.8em;
  }
  a:hover {
    font-weight: bold;
  }
  ul{
    list-style-type: none;
  }
</style>
