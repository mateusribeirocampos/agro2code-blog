{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "pubDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "draft": {
          "type": "boolean"
        },
        "lang": {
          "type": "string",
          "enum": [
            "en",
            "pt"
          ]
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "heroImage": {
          "type": "string"
        },
        "series": {
          "type": "string"
        },
        "canonicalSlug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "portfolioFeatured": {
          "type": "boolean"
        },
        "portfolioSummary": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "author",
        "pubDate",
        "draft",
        "lang",
        "category",
        "tags",
        "canonicalSlug"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}